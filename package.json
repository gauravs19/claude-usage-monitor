{
  "name": "claude-usage-monitor",
  "displayName": "Claude Usage Monitor",
  "description": "Real-time Claude Code token usage and activity in the VS Code status bar",
  "version": "0.1.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeUsage.openPanel",
        "title": "Claude Usage: Open Dashboard"
      },
      {
        "command": "claudeUsage.refresh",
        "title": "Claude Usage: Refresh"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
