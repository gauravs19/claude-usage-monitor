{
  "name": "claude-usage-monitor",
  "displayName": "Claude Usage Monitor",
  "description": "Real-time Claude Code token usage, subscription rate limits, and session efficiency in the VS Code status bar",
  "version": "0.2.3",
  "publisher": "gauravs19",
  "author": {
    "name": "Gaurav Sharma",
    "url": "https://github.com/gauravs19"
  },
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/gauravs19/claude-usage-monitor"
  },
  "homepage": "https://github.com/gauravs19/claude-usage-monitor#readme",
  "bugs": {
    "url": "https://github.com/gauravs19/claude-usage-monitor/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "token-usage",
    "ai",
    "usage-monitor",
    "rate-limit",
    "anthropic",
    "statusbar"
  ],
  "engines": { "vscode": "^1.85.0" },
  "galleryBanner": {
    "color": "#1A1A1A",
    "theme": "dark"
  },
  "categories": ["Other", "Visualization"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeUsage.openPanel",
        "title": "Claude Usage: Open Dashboard"
      },
      {
        "command": "claudeUsage.refresh",
        "title": "Claude Usage: Refresh"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "compile": "tsc -p ./",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "package": "vsce package",
    "vscode:prepublish": "node esbuild.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
